#!/usr/bin/env bash

USAGE="<branch_name> [--from <base_branch>]"
LONG_USAGE="Creates a branch starting from <base_branch>, or DEVELOPMENT_BRANCH when omitted. Generated branch names include from-<short_base_branch>."

source "$(git --exec-path)/git-sh-setup"
source "git-line_utils.bash"

setup_configuration

BASE_BRANCH=$DEVELOPMENT_BRANCH
base_branch_was_provided=false

if [[ $# -gt 0 ]]; then
    shift
fi

BRANCH_NAME=${1:-}

if [[ $# -gt 0 ]]; then
    shift
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --from)
            if [[ $# -lt 2 ]] || [[ "$base_branch_was_provided" == "true" ]]; then
                usage
                exit 1
            fi

            BASE_BRANCH=$2
            base_branch_was_provided=true
            shift 2
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

BASE_BRANCH=$(echo "$BASE_BRANCH" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
BASE_BRANCH_NAME=$(git_line_sanitize_branch_name "$(git_line_short_branch_name "$BASE_BRANCH")")
BRANCH_NAME=$(echo "$BRANCH_NAME" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' | tr \  -)

if [[ -z $BASE_BRANCH ]] || [[ -z $BRANCH_NAME ]] || [[ $BRANCH_NAME == -* ]]; then
    usage
    exit 1
fi

current_branch=$(git rev-parse --abbrev-ref HEAD)

timestamp=$(date +%T)
git stash push -m "git-line-start-$current_branch-$timestamp"

git checkout "$BASE_BRANCH"

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    git pull --ff-only
fi

BRANCH_NAME="from-$BASE_BRANCH_NAME/$BRANCH_NAME"

if [[ "$BRANCH_PREFIX_ENABLED" == "true" ]]; then
    BRANCH_NAME="$BRANCH_PREFIX/$BRANCH_NAME"
fi

git checkout -b "$BRANCH_NAME"
git config "branch.$BRANCH_NAME.git-line-base-branch" "$BASE_BRANCH"
