#!/usr/bin/env bash

USAGE=""
LONG_USAGE="Remove all remote branches removed from origin and all local branches which remote is gone. It will not remove branches which never had remotes."

source "$(git --exec-path)/git-sh-setup"
source "git-line_utils.bash"

setup_configuration

git fetch --all --prune

mapfile -t branches_with_gone_remote < <(git branch -vv | cut -c 3- | awk '$4 ~/gone\]/ { print $1}')

current_branch=$(git rev-parse --abbrev-ref HEAD)

for branch in "${branches_with_gone_remote[@]}"; do
    if [[ $branch == "$current_branch" ]]; then
        git checkout "$DEVELOPMENT_BRANCH"
        break
    fi
done

if [[ ${#branches_with_gone_remote[@]} -gt 0 ]]; then
    git branch -D "${branches_with_gone_remote[@]}"
fi
